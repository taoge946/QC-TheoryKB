	keywords = {constant overhead quantum fault-tolerance, constant rate quantum codes, decoding, Decoding, decoding algorithm, expander codes, Fault tolerance, fault tolerant computing, Fault tolerant systems, fault-tolerant circuits, Graph theory, logical qubits, Noise measurement, noisy syndrome measurement, percolation, physical error rate, quantum computation, quantum computing, quantum expander codes, quantum fault-tolerance techniques, single-shot quantum error correction, standard threshold theorem},
	pages = {743--754},
	file = {Eingereichte Version:/Users/jenseberhardt/Zotero/storage/6QGJKJMA/Fawzi et al. - 2018 - Constant Overhead Quantum Fault-Tolerance with Qua.pdf:application/pdf;IEEE Xplore Abstract Record:/Users/jenseberhardt/Zotero/storage/GUYS3UQS/8555154.html:text/html},

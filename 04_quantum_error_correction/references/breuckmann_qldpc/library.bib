@article{agarwal_expansion_2019,
	title = {On the {Expansion} of {Group}-{Based} {Lifts}},
	volume = {33},
	issn = {0895-4801},
	url = {https://epubs.siam.org/doi/10.1137/17M1141047},
	doi = {10.1137/17M1141047},
	abstract = {A \$k\$-lift of an \$n\$-vertex base graph \$G\$ is a graph \$H\$ on \$n{\textbackslash}times k\$ vertices, where each vertex \$v\$ of \$G\$ is replaced by \$k\$ vertices \$v\_1,{\textbackslash}ldots,v\_k\$ and each edge \$uv\$ in \$G\$ is replaced by a matching representing a bijection \${\textbackslash}pi\_\{uv\}\$ so that the edges of \$H\$ are of the form \$(u\_i,v\_\{{\textbackslash}pi\_\{uv\}(i)\})\$. Lifts have been investigated as a means to efficiently construct expanders. In this work, we study lifts obtained from groups and group actions. We derive the spectrum of such lifts via the representation theory principles of the underlying group. Our main results are 1. a uniform random lift by a cyclic group of order \$k\$ of any \$n\$-vertex \$d\$-regular base graph \$G\$, with the nontrivial eigenvalues of the adjacency matrix of \$G\$ bounded by \${\textbackslash}lambda\$ in magnitude, has the new nontrivial eigenvalues bounded by \${\textbackslash}lambda+{\textbackslash}mathcal\{O\}({\textbackslash}sqrt\{d\})\$ in magnitude with probability \$1-ke{\textasciicircum}\{-{\textbackslash}Omega(n/d{\textasciicircum}2)\}\$. The probability bounds as well as the dependency on \${\textbackslash}lambda\$ are almost optimal. As a special case, we obtain that there is a constant \$c\_1\$ such that for every \$k{\textbackslash}leq 2{\textasciicircum}\{c\_1n/d{\textasciicircum}2\}\$, there exists a lift \$H\$ of every Ramanujan graph by a cyclic group of order \$k\$ such that \$H\$ is almost Ramanujan (nontrivial eigenvalues of the adjacency matrix at most \$O({\textbackslash}sqrt\{d\})\$ in magnitude). This result leads to a quasi-polynomial time deterministic algorithm to construct almost Ramanujan expanders; 2. there is a constant \$c\_2\$ such that for every \$k{\textbackslash}geq 2{\textasciicircum}\{c\_2nd\}\$, there does not exist an abelian \$k\$-lift \$H\$ of any \$n\$-vertex \$d\$-regular base graph such that \$H\$ is almost Ramanujan. This can be viewed as an analogue of the well-known nonexpansion result for constant degree abelian Cayley graphs. Suppose \$k\_0\$ is the order of the largest abelian group that produces expanding lifts. Our two results highlight lower and upper bounds on \$k\_0\$ that are tight up to a factor of \$d{\textasciicircum}3\$ in the exponent, thus suggesting a threshold phenomenon.},
	number = {3},
	urldate = {2021-02-07},
	journal = {SIAM Journal on Discrete Mathematics},
	author = {Agarwal, Naman and Chandrasekaran, Karthekeyan and Kolla, Alexandra and Madan, Vivek},
	month = jan,
	year = {2019},
	note = {Publisher: Society for Industrial and Applied Mathematics},
	pages = {1338--1373},
	file = {Snapshot:/Users/jenseberhardt/Zotero/storage/QTN2LJYE/17M1141047.html:text/html;Eingereichte Version:/Users/jenseberhardt/Zotero/storage/WXFT2SBT/Agarwal et al. - 2019 - On the Expansion of Group-Based Lifts.pdf:application/pdf},
}

